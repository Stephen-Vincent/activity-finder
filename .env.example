# Activity Finder — environment variables
# Copy to .env and fill in. Never commit a real .env.
#
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the client bundle.
# Anything secret (service role keys, Stripe secret keys, webhook signing secrets)
# must NOT use the EXPO_PUBLIC_ prefix and should only be used server-side
# (Supabase Edge Functions, scripts, CI).

# ---- Supabase ----
# Public (mobile app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only (Edge Functions / scripts)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ---- Mapbox ----
# Public token: used at runtime by the mobile app to render the map.
EXPO_PUBLIC_MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token
# Secret download token: read by the @rnmapbox/maps Expo plugin at prebuild
# time to authorise the native SDK download. Must use this exact name.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.your_mapbox_secret_token

# ---- Stripe ----
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Weather (Met Éireann / Met Office or OpenWeather as a fallback) ----
EXPO_PUBLIC_WEATHER_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ---- PostHog (analytics, EU region) ----
EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---- Sentry ----
EXPO_PUBLIC_SENTRY_DSN=https://xxx.ingest.sentry.io/xxx

# ---- Resend (transactional email, server-only) ----
RESEND_API_KEY=re_xxx

# ---- Affiliate partners (server-only) ----
TIQETS_PARTNER_ID=
GETYOURGUIDE_PARTNER_ID=

# ---- Environment ----
APP_ENV=development
